# PACT Day 0 validation — environment template
# Copy to .env and fill what you need. Never commit .env.
#
# Per gate:
#   G3, G4 → only PACT_ROUTER_API_KEY (and optionally MODEL/BASE_URL).
#            No wallet involved. The Router debits your pc.0g.ai prepaid pool.
#   G5, G6 → only PACT_PRIVATE_KEY (a fresh burner). The Router fields are
#            ignored. Burner needs ~5 $0G of native gas + ledger seed.
#   G7     → no env at all (local Foundry compile).
#
# Leave keys blank if you aren't running the gate that needs them.

# ---------------------------------------------------------------------------
# Wallet / chain (G5, G6)
# ---------------------------------------------------------------------------
# Burner private key. Funded with ~5 $0G native gas. NOT your dashboard wallet.
# 0x-prefixed 32-byte hex. Blank or "0x" = treated as unset.
PACT_PRIVATE_KEY=

# 0G mainnet RPC (PRD primary).
PACT_RPC_URL=https://evmrpc.0g.ai

# 0G mainnet chain id. Do not change.
PACT_CHAIN_ID=16661

# ---------------------------------------------------------------------------
# 0G Compute Router (G3, G4)
# ---------------------------------------------------------------------------
# OpenAI-compatible base URL.
PACT_ROUTER_BASE_URL=https://router-api.0g.ai/v1

# `sk-…` API key from pc.0g.ai → Dashboard → API Keys. Debits your prepaid
# Router pool. No wallet signature per call.
PACT_ROUTER_API_KEY=

# Model identifier. Verified default per 0G Router docs.
PACT_ROUTER_MODEL=zai-org/GLM-5-FP8

# ---------------------------------------------------------------------------
# 0G Storage (G6)
# ---------------------------------------------------------------------------
PACT_STORAGE_INDEXER_URL=https://indexer-storage-turbo.0g.ai

# ---------------------------------------------------------------------------
# Optional: pin a specific Direct-broker provider for G5. Blank = first found.
# ---------------------------------------------------------------------------
PACT_BROKER_PROVIDER_ADDRESS=
