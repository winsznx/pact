# PACT contracts — deploy environment template.
# Copy to .env and fill in. NEVER commit .env.

# ────────────────────────────────────────────────────────────────────
# Deploy (Step 2F / 2G)
# ────────────────────────────────────────────────────────────────────

# 0x-prefixed 32-byte hex private key for the deployer wallet.
# Funded with ≥ ~3 $0G to cover the 8-step deploy + a margin. The
# deployer ends up holding AgentNFT's DEFAULT_ADMIN_ROLE / ADMIN_ROLE /
# OPERATOR_ROLE / MINTER_ROLE — keep the key safe or rotate after
# deploy via setAdmin.
PACT_DEPLOYER_PRIVATE_KEY=

# Treasury address — receives protocol fees from PactEscrow.sweepFees()
# and slash shares from SlashingArbiter.arbitrate(). Should be a
# multisig in production; an EOA is acceptable for hackathon demos.
# Cannot be address(0) — deploy reverts.
PACT_TREASURY=

# 0G mainnet RPC. PRD §16.1 primary.
PACT_RPC_URL=https://evmrpc.0g.ai

# ────────────────────────────────────────────────────────────────────
# Verify (Step 2G — chainscan.0g.ai source verification)
# ────────────────────────────────────────────────────────────────────

# Blockscout-compatible verifier endpoint. Default points at chainscan.0g.ai's
# conventional /api path; CONFIRM against 0G docs before running. If
# verification fails with HTTP errors, this is the first thing to check.
PACT_VERIFIER_URL=https://chainscan.0g.ai/api
