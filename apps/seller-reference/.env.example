# Copy to apps/seller-reference/.env and fill in.
#
# The seller wallet — MUST be the same wallet that called registerService
# on Service 1 (i.e. the smoke-test burner). Both stakeBond() and
# submitAttestation() require msg.sender == svc.seller.
PACT_PRIVATE_KEY=

# 0G mainnet RPC. Default is fine.
PACT_RPC_URL=https://evmrpc.0g.ai

# Service to serve. v0.1 only Service 1 is registered.
PACT_SERVICE_ID=1

# 0G Compute Direct-broker provider (G5 from Phase 0 — TEE-attested).
PACT_BROKER_PROVIDER_ADDRESS=0xd9966e13a6026Fcca4b13E7ff95c94DE268C471C

# Watcher poll interval, milliseconds. 3000ms matches the frontend
# useJob() polling interval — keeps the demo loop tight.
PACT_POLL_INTERVAL_MS=3000
