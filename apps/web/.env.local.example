# Copy to apps/web/.env.local and fill in.
#
# WalletConnect projectId — provision at https://cloud.walletconnect.com.
# Until set, RainbowKit logs a "no projectId" warning that surfaces as
# Next's dev-tools "1 error" toast in the bottom-left corner of every
# screenshot. Cosmetic only; wallet connect still works.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Demo-mode mock state gate. Only ever enabled in dev.
# When set to "1", /verify/[jobId]?mockState=settled (or mockState=attested)
# bypasses the chain read and renders the captured G5 fixture so the ECDSA
# recovery viz can be exercised without waiting for Phase 4's seller agent
# to submit a real attestation.
NEXT_PUBLIC_DEMO_MOCK=1
