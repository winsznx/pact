# PACT indexer — runtime configuration.
# Set in Railway dashboard (Service → Variables) for production.

# HTTP listener. Railway injects PORT automatically; defaults to 8080.
PORT=8080

# 0G mainnet RPC. Primary: https://evmrpc.0g.ai.
PACT_RPC_URL=https://evmrpc.0g.ai

# Start-of-history block for the initial scan. 30_000_000 is the post-
# deploy floor (Phase 1 EXIT.1, 2026-05-08). Adjust if redeploying to
# a different chain.
PACT_DEPLOY_BLOCK=30000000

# Poll cadence in milliseconds. 3s matches the seller agent.
PACT_POLL_MS=3000
